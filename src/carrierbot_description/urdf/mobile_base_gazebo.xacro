<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <gazebo reference="base_link">
        <material>Gazebo/Blue</material>
    </gazebo>
    <gazebo reference="upper_base_link">
        <material>Gazebo/Red</material>
    </gazebo>
    <gazebo reference="right_wheel_link">
        <material>Gazebo/Red</material>
    </gazebo>
    <gazebo reference="left_wheel_link">
        <material>Gazebo/Red</material>
    </gazebo>
    <gazebo reference="caster_wheel_link">
        <material>Gazebo/Green</material> 
        <mu1 value="0.1" /> <!-- Fix caster wheel error -->
        <mu2 value="0.1" />
    </gazebo>

    <!-- ros2_control -->
    <gazebo>
        <xacro:if value="$(arg is_ignition)">
            <plugin filename="ign_ros2_control-system" name="ign_ros2_control::IgnitionROS2ControlPlugin">
                <parameters>$(find carrierbot_controller)/config/robot_controller.yaml</parameters>
            </plugin>     
        </xacro:if>

        <xacro:unless value="$(arg is_ignition)">
            <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
                <parameters>$(find carrierbot_controller)/config/robot_controller.yaml</parameters>
            </plugin>  
        </xacro:unless>
    </gazebo>

    <!-- This is for diff drive. If not uncomment this, the robot will not move with ros2 control -->
    <!-- <gazebo>
        <plugin 
            filename="gz-sim-diff-drive-system" 
            name="gz::sim::systems::DiffDrive"> 
            <left_joint>base_left_wheel_joint</left_joint>
            <right_joint>base_right_wheel_joint</right_joint>
            <wheel_separation>0.45</wheel_separation> 
            <wheel_diameter>0.2</wheel_diameter>
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin
            filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
            <joint_name>base_left_wheel_joint</joint_name>
            <joint_name>base_right_wheel_joint</joint_name>
        </plugin>
    </gazebo> -->

</robot>